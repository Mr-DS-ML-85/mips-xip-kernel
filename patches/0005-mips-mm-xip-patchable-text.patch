From: Irfan <irfan@localhost>
Subject: [PATCH 5/5] MIPS: mm: move runtime-patched uasm buffers to RAM for XIP

The TLB handlers (handle_tlbl/s/m, tlbmiss_handler_setup_pgd) and
clear_page/copy_page are uasm-generated at boot into .text buffers.
Under XIP .text is ROM: the patch writes are silently dropped and the
placeholder "j 1b" spins forever. Move the buffers to a new RAM
section .data..xip_patchable_text (KSEG0 has no per-page execute
permissions, so RAM-resident code is executable).

Callers reach them through ROM trampolines (PTR_LA t9 + jr) because
jal/R_MIPS_26 cannot cross the 256 MiB jump segment between the flash
window (0x9fcxxxxx) and RAM (0x80xxxxxx). For the same reason the
generated absolute jumps to tlb_do_page_fault_0/1 become
lui/addiu/jr via build_tlb_fault_jump().
---
--- a/arch/mips/mm/tlb-funcs.S
+++ b/arch/mips/mm/tlb-funcs.S
@@ -17,12 +17,45 @@
 
 #define FASTPATH_SIZE	128
 
+#ifdef CONFIG_XIP_KERNEL
+/*
+ * These are not real functions but buffers that mm/tlbex.c fills with
+ * runtime-generated (uasm) handler code. With an XIP kernel, .text
+ * executes in place from ROM and cannot be written to, so the patchable
+ * buffers must live in the RAM data region (placed in .data by
+ * vmlinux-xip.lds.S). KSEG0 is not subject to per-page execute
+ * protection, so executing them from there is fine.
+ *
+ * tlbmiss_handler_setup_pgd is additionally *called directly* (jal)
+ * from C code, and the RAM buffer usually sits in a different 256 MiB
+ * jump segment than the flash-resident callers, out of jal's reach:
+ * keep a register-jump trampoline in .text under the original symbol.
+ * mm/tlbex.c generates the real code into xip_tlbmiss_handler_setup_pgd.
+ * handle_tlb{l,s,m} are only ever dispatched indirectly through
+ * exception_handlers[], so they need no trampolines.
+ */
+LEAF(tlbmiss_handler_setup_pgd)
+	PTR_LA	t9, xip_tlbmiss_handler_setup_pgd
+	jr	t9
+END(tlbmiss_handler_setup_pgd)
+EXPORT_SYMBOL_GPL(tlbmiss_handler_setup_pgd)
+
+	.section .data..xip_patchable_text, "aw", @progbits
+	.balign	8
+
+LEAF(xip_tlbmiss_handler_setup_pgd)
+1:	j	1b		/* Dummy, will be replaced. */
+	.space	64
+END(xip_tlbmiss_handler_setup_pgd)
+EXPORT(tlbmiss_handler_setup_pgd_end)
+#else
 LEAF(tlbmiss_handler_setup_pgd)
 1:	j	1b		/* Dummy, will be replaced. */
 	.space	64
 END(tlbmiss_handler_setup_pgd)
 EXPORT(tlbmiss_handler_setup_pgd_end)
 EXPORT_SYMBOL_GPL(tlbmiss_handler_setup_pgd)
+#endif
 
 LEAF(handle_tlbm)
 	.space		FASTPATH_SIZE * 4
--- a/arch/mips/mm/page-funcs.S
+++ b/arch/mips/mm/page-funcs.S
@@ -28,6 +28,29 @@
  * R4600 v2.0:				0x060 bytes
